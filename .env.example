# =============================================================================
# Site Orchestrator — environment template
# Copy this file to .env and fill in real values. Never commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Salesforce
# -----------------------------------------------------------------------------
SF_USERNAME=your-salesforce-username
SF_PASSWORD=your-salesforce-password
SF_SECURITY_TOKEN=your-salesforce-security-token
SF_DOMAIN=login

# -----------------------------------------------------------------------------
# Geocoding (Google Maps Geocoding API)
# -----------------------------------------------------------------------------
GEOCODE_API_KEY=your-google-maps-api-key

# -----------------------------------------------------------------------------
# Classifier API keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here
NEARMAP_API_KEY=your-nearmap-key
GEMINI_API_KEY=your-gemini-key

# -----------------------------------------------------------------------------
# Pipeline mode flags
# -----------------------------------------------------------------------------
NEARMAP_TIERED=0
BIFURCATED_AI=0
NAIP_ONLY=0

# -----------------------------------------------------------------------------
# AI model settings
# -----------------------------------------------------------------------------
CLAUDE_MODELS=claude-sonnet-4-6,claude-haiku-4-5-20251001
CLAUDE_ESCALATION_MODEL=claude-sonnet-4-6
GEMINI_MODEL=gemini-2.5-flash
CLAUDE_DELAY_S=12
TIER_CONF_HIGH=0.75
TIER_CONF_MEDIUM=0.6

# -----------------------------------------------------------------------------
# Classifier geocoding (Census / Nominatim fallback)
# -----------------------------------------------------------------------------
GEOCODER=auto
GEOCODER_USER_AGENT=site-orchestrator/1.0 (cell-site imagery pipeline)
