# =============================================================================
# Site Orchestrator — environment template
# Copy this file to .env and fill in real values. Never commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Salesforce (UAT sandbox)
# -----------------------------------------------------------------------------
SF_USERNAME=your-uat-username
SF_PASSWORD=your-uat-password
SF_SECURITY_TOKEN=your-uat-security-token
# Standard sandbox: test | Custom My Domain sandbox: yourorg--uat.sandbox
SF_DOMAIN=symphonyinfra--uat.sandbox

# -----------------------------------------------------------------------------
# Geocoding (US Census + Nominatim — shared by orchestrator ingest and classifier)
# Set GEOCODER=auto (default), census, or nominatim.
# -----------------------------------------------------------------------------
GEOCODER=auto
GEOCODER_USER_AGENT=site-orchestrator/1.0 (cell-site imagery pipeline)

# Urbanicity search radii use US ZCTA populations from a CSV (zip,population columns).
# Works nationwide — point at a full Census ZCTA export or a regional subset.
# Example regional file: data/zip_populations.csv (Milwaukee sample)
# ZIP_POPULATION_CSV=data/zip_populations.csv

# Geocode Salesforce Site__c rows missing Site_Latitude__c/Site_Longitude__c during dedupe prefetch.
# Set to 0 to disable (spatial scoring falls back to address-only for those records).
SF_GEOCODE_MISSING=1

# Salesforce upload defaults (sf_upload.csv template + API create)
# Carrier_Leasing_Source__c auto-generates as PermitScraping_{mon}{year} (e.g. PermitScraping_jun2026)
# SF_CARRIER_LEASING_SOURCE=PermitScraping_jun2026
SF_DEFAULT_VERIFIED_SOURCE=Permitting Data
# SF_DEFAULT_PROPERTY_TYPE=Commercial
# Override API field names when your org uses different Site__c custom fields:
# SF_FIELD_CARRIER_LEASING_SOURCE=Carrier_Leasing_Source__c
# SF_FIELD_SITE_STREET=Street__c

# -----------------------------------------------------------------------------
# Classifier API keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here
NEARMAP_API_KEY=your-nearmap-key
GEMINI_API_KEY=your-gemini-key

# -----------------------------------------------------------------------------
# Pipeline mode flags
# -----------------------------------------------------------------------------
NEARMAP_TIERED=1
BIFURCATED_AI=1
NAIP_ONLY=0

# -----------------------------------------------------------------------------
# AI model settings
# -----------------------------------------------------------------------------
CLAUDE_MODELS=claude-sonnet-4-6,claude-haiku-4-5-20251001
CLAUDE_ESCALATION_MODEL=claude-sonnet-4-6
GEMINI_MODEL=gemini-2.5-flash
CLAUDE_DELAY_S=12
TIER_CONF_HIGH=0.75
TIER_CONF_MEDIUM=0.6
