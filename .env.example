# =============================================================================
# Asset Classifier — environment template
# Copy this file to .env and fill in real values. Never commit .env to git.
# Loaded automatically at startup via python-dotenv (see asset_classifier.py).
# Shell variables ($env:VAR=...) override values here if both are set.
# =============================================================================

# -----------------------------------------------------------------------------
# API keys
# -----------------------------------------------------------------------------

# Required for every run. Claude vision classification (default provider).
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Nearmap Tile API key. Enables high-res vertical + 4 oblique views per site.
# Without this key the pipeline runs on NAIP imagery only (no Nearmap tiles).
NEARMAP_API_KEY=your-nearmap-key

# Gemini API key. Required only when BIFURCATED_AI=1 (Gemini first pass).
GEMINI_API_KEY=your-gemini-key

# -----------------------------------------------------------------------------
# Pipeline mode flags
# Set to 1 to enable, 0 to disable. All default to 0 (legacy behavior).
# -----------------------------------------------------------------------------

# Tiered Nearmap fetch: NAIP only → add Vert → add N/E/S/W obliques.
# Stops early when site_type is tower/rooftop, confidence is medium/high,
# and cell_equipment is known. Saves Nearmap tile quota on easy sites.
NEARMAP_TIERED=0

# Gemini-first classification with Claude escalation. Gemini runs on every site;
# Claude is called only when Gemini returns other, unclear, or low confidence.
# Requires GEMINI_API_KEY. Does NOT route on input_confidence from the CSV.
BIFURCATED_AI=0

# Debug/breakpoint mode: skip all Nearmap fetching entirely. Runs classification
# on NAIP imagery only. Overrides NEARMAP_TIERED. Good for fast local testing.
NAIP_ONLY=0

# -----------------------------------------------------------------------------
# AI model settings
# -----------------------------------------------------------------------------

# Comma-separated Claude models. First is primary; hops to next on rate limits
# or 404. Used when BIFURCATED_AI=0, and for wide-AOI/zoom/escalation paths.
CLAUDE_MODELS=claude-sonnet-4-6,claude-haiku-4-5-20251001

# Fixed Claude model for bifurcated escalation (no fallback chain).
CLAUDE_ESCALATION_MODEL=claude-sonnet-4-6

# Gemini model for first-pass classification when BIFURCATED_AI=1.
GEMINI_MODEL=gemini-2.5-flash

# Seconds to pause between assets. Helps stay under API rate limits.
CLAUDE_DELAY_S=12

# -----------------------------------------------------------------------------
# Tiered Nearmap gating thresholds
# Only used when NEARMAP_TIERED=1. Maps numeric site_confidence to bands.
# -----------------------------------------------------------------------------

# site_confidence >= this value → "high" band (eligible to stop fetching).
TIER_CONF_HIGH=0.75

# site_confidence >= this value (and below high) → "medium" band.
TIER_CONF_MEDIUM=0.6

# -----------------------------------------------------------------------------
# Geocoding
# -----------------------------------------------------------------------------

# How to resolve street addresses to lat/lon: auto (Census then Nominatim),
# census (US Census Geocoder only), or nominatim (OpenStreetMap only).
GEOCODER=auto

# User-Agent header sent with Nominatim requests (required by their usage policy).
GEOCODER_USER_AGENT=site-classifier/1.0 (cell-site imagery pipeline)
